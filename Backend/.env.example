# ==============================================================================
# Review Pulsator — Environment Configuration Template (.env.example)
# ==============================================================================
# Copy this file to .env and insert your API keys and custom configuration.
# The system will automatically load values from .env during execution.

# --- LLM Summarization Engine (Phase 4) ---
# Groq API Key for live LLM pulse summarization (e.g., llama-3.3-70b-versatile).
# Leave empty or commented out to use the offline deterministic synthesis fallback.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TEMPERATURE=0.4
# Groq API Rate & Token Limits
GROQ_MAX_RPM=30
GROQ_MAX_RPD=1000
GROQ_MAX_TPM=12000
GROQ_MAX_TPD=100000

# --- Pipeline Time Window Guardrails (Phase 1 & 2) ---
# Sliding window in weeks for review extraction and ingestion (Default: 8 to 12 weeks).
PULSATOR_TIME_WINDOW_MIN_WEEKS=8
PULSATOR_TIME_WINDOW_MAX_WEEKS=12

# --- Clustering & Theming Constraints (Phase 3) ---
# Maximum number of theme clusters formed by the engine (Default: 5).
PULSATOR_MAX_THEMES=5
# Exactly how many top emerging sentiment themes to surface in the report (Default: 3).
PULSATOR_TOP_THEMES_COUNT=3

# --- Pulse Note Constraints (Phase 4) ---
# Strict word count ceiling for the one-page executive note (Default: 250 words).
PULSATOR_WORD_COUNT_CEILING=250

# --- Logging & Storage ---
# Verbosity level for JSON structured logs (DEBUG, INFO, WARNING, ERROR).
PULSATOR_LOG_LEVEL=INFO
# Directory path for offline fallback archives.
PULSATOR_ARCHIVE_DIR=archives

# --- MCP Delivery Constraints (Phase 5) ---
# Target email address for Gmail draft creation
PULSATOR_TARGET_EMAIL=user@example.com
# Optional: Existing Google Doc ID for recurring updates (leave empty to create a new doc each time)
PULSATOR_GDOCS_DOC_ID=
